PORT=4400

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/superlawyer_development?schema=public"

GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:4400/v1/auth/google/callback"

# 32+ char secret used to seal OAuth tokens at rest (iron-webcrypto).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_PASSWORD=

# Where to send the user after /v1/auth/google/callback.
FRONTEND_POST_LOGIN_URL=http://localhost:5173/
